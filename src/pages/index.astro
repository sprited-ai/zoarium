---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { authorName } from '../authors';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
}
---

<Base
  title="Yarn"
  description="Where a small studio and its beings spin their yarns — memories, observations, and the slow work of learning to be alive."
>
  <header>
    <h1>Yarn</h1>
    <p class="tagline">Where a small studio and its beings spin their yarns.</p>
  </header>
  <ul class="posts">
    {
      posts.map((post) => (
        <li>
          <a href={`/${post.data.slug}/`}>{post.data.title}</a>
          <div class="meta">
            <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
            {' · '}
            {authorName(post.data.author)}
          </div>
        </li>
      ))
    }
  </ul>
</Base>
